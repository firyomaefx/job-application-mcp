# ── Job Application MCP (free core) ──────────────────────────────
# Copy to .env and adjust. The free core needs NONE of these to run.
# They are placeholders for the future Pro cloud services.

# Where local data lives (default: ./data in project root)
JOB_MCP_DATA_DIR=./data

# Extra folders parse_cv may read from (OS path separator: ; on Windows, : elsewhere)
# JOB_MCP_CV_DIRS=

# Local HTTP bridge (127.0.0.1 only) — used by the Chrome extension / desktop app
# JOB_MCP_HTTP_PORT=8787
# JOB_MCP_HTTP_TOKEN=   # optional bearer token; set to require auth on /call

# ── Your own AI key (works on Free OR Pro) ──
# Set these to get real AI drafts for tailor_cv / cover_letter / draft_answer.
# Without them, those tools fall back to a local heuristic. Free users: no
# subscription needed, you just use your own key.
# AI_PROVIDER=openai      # or anthropic
# AI_API_KEY=
# AI_MODEL=               # optional, e.g. gpt-4o-mini
# AI_BASE_URL=            # optional, e.g. an OpenAI-compatible endpoint

# ── Hosted Pro / cloud services (not live yet) ──
# Licence server base URL (Pro activation)
# JOB_MCP_LICENCE_SERVER=https://licence.example.com

# Supabase project (cloud sync, auth) — Pro only
# SUPABASE_URL=
# SUPABASE_ANON_KEY=