# ── Job Application MCP (free core) ──────────────────────────────
# Copy to .env and adjust. The free core needs NONE of these to run.
# They are placeholders for the future Pro cloud services.

# Where local data lives (default: ./data in project root)
JOB_MCP_DATA_DIR=./data

# ── Pro / cloud services (not used by free core) ──
# Licence server base URL (Pro activation)
# JOB_MCP_LICENCE_SERVER=https://licence.example.com

# Supabase project (cloud sync, auth) — Pro only
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# AI provider (Pro AI tailoring) — Pro only
# AI_PROVIDER=
# AI_API_KEY=