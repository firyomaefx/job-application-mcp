{
  "name": "job-application-mcp-desktop",
  "version": "0.4.1",
  "private": true,
  "description": "Desktop wrapper UI for Job Application MCP. Launches the local HTTP bridge and shows your profile, applications, and server status.",
  "license": "AGPL-3.0-or-later",
  "author": "Job Application MCP contributors",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node build-icon.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-updater": "^6.3.0"
  },
  "build": {
    "appId": "io.github.jobapplicationmcp.desktop",
    "productName": "Job Application MCP",
    "files": ["main.js", "preload.js", "renderer/**/*"],
    "extraResources": [
      { "from": "bridge-bundle.mjs", "to": "bridge-bundle.mjs" }
    ],
    "directories": { "output": "release" },
    "icon": "icons/icon.png",
    "publish": {
      "provider": "github",
      "owner": "firyomaefx",
      "repo": "job-application-mcp"
    },
    "mac": { "target": "dmg" },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "signAndEditExecutable": false
    },
    "nsis": { "oneClick": true, "perMachine": false },
    "linux": { "target": "AppImage" }
  }
}