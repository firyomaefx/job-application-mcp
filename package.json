{
  "name": "job-application-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first, open-source job application assistant built on the Model Context Protocol. Free community core.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "job-mcp": "dist/cli/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/cli.js",
    "serve": "node dist/src/index.js",
    "test": "node --test --import tsx tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "job-application",
    "cv",
    "career",
    "open-source"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.8.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}