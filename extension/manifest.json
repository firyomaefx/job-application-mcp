{
  "manifest_version": 3,
  "name": "Job Application MCP — Form Capture & Job Import",
  "version": "0.2.1",
  "description": "Capture form fields and one-click import job postings on a career page into your local Job Application MCP profile. Nothing is submitted.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*",
    "https://*.lever.co/*",
    "https://*.greenhouse.io/*",
    "https://*.workday.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.bamboohr.com/*",
    "https://*.jobvite.com/*",
    "https://*.taleo.net/*",
    "https://*.myworkdayjobs.com/*"
  ],
  "action": {
    "default_title": "Job Application MCP",
    "default_popup": "popup/popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.linkedin.com/job/*",
        "https://*.indeed.com/*viewjob*",
        "https://*.indeed.com/*jk=*",
        "https://*.glassdoor.com/*job-listing*",
        "https://jobs.lever.co/*",
        "https://*.lever.co/*",
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://*.workday.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.bamboohr.com/*",
        "https://*.jobvite.com/*",
        "https://*.taleo.net/*"
      ],
      "js": ["content/extract.js", "content/import-detector.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": { "page": "options/options.html", "open_in_tab": false }
}